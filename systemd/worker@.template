# Template for a per-experiment WORKER service: a long-lived background process
# with NO HTTP port and NO Caddy route (e.g. a Telegram long-polling bot).
# Generated into ~/.config/systemd/user/exp-<slug>.service by register-experiment.sh.
# Placeholders (@@...@@) are substituted at generation time. Do not install directly.
[Unit]
Description=Experiment worker: @@SLUG@@
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=@@APPDIR@@
ExecStart=@@NODE@@ @@APPDIR@@/@@ENTRY@@
Environment=NODE_ENV=production
# Shared secrets (TELEGRAM_BOT_TOKEN / TELEGRAM_CHAT_ID, etc.). Leading '-' = optional.
EnvironmentFile=-%h/claude-os/config/notify.env
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
