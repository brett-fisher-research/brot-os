# Template for the home dashboard service. Generated into
# ~/.config/systemd/user/exp-home.service by bin/rebuild-home.sh.
# Placeholders (@@...@@) are substituted at generation time. Do not install this file directly.
#
# The home app is special: it serves the root route '/', has NO basePath, runs on the
# reserved port 2999 (below the 3001 experiment floor), and lives in the monorepo (no per-app repo).
[Unit]
Description=Home dashboard (claude-os landing)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=@@APPDIR@@
# Next.js standalone server (output: 'standalone'). Binds to localhost only;
# Tailscale + Caddy handle external access.
ExecStart=@@NODE@@ @@APPDIR@@/.next/standalone/server.js
Environment=NODE_ENV=production
Environment=PORT=@@PORT@@
Environment=HOSTNAME=127.0.0.1
# The dashboard reads registry.json + data/feature-ideas/ from the repo root at request time.
Environment=CLAUDE_EXPERIMENTS_ROOT=@@ROOT@@
# Optional Cloudflare API creds for the Observability traffic widget (CLOUDFLARE_API_TOKEN,
# CLOUDFLARE_ZONE_ID, CF_ANALYTICS_DAYS). Leading '-' => fine if the file is absent.
EnvironmentFile=-%h/claude-os/config/cloudflare.env
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
