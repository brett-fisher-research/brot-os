# Cloudflare analytics secrets — copy to cloudflare.env and fill in, then `chmod 600 cloudflare.env`.
#
# ONE API token covers everything here. Create/edit it at:
#   Cloudflare dashboard -> My Profile -> API Tokens -> Create (or edit) Token
# Permissions it needs:
#   - Account -> Account Analytics -> Read   (REQUIRED for Web Analytics / RUM per-page views)
#   - Zone    -> Analytics        -> Read    (only if you also use zone traffic analytics)
CLOUDFLARE_API_TOKEN=

# Account ID — dash.cloudflare.com/<ACCOUNT_ID>/... or Account Home -> right sidebar "Account ID".
# Required: the RUM (Web Analytics) GraphQL dataset lives under the ACCOUNT, not the zone.
CLOUDFLARE_ACCOUNT_ID=

# Web Analytics beacon SITE TAG — the "token" inside the beacon <script> snippet Cloudflare gives
# you when you add brettfisher.dev under Analytics & Logs -> Web Analytics. Identifies the site in
# the rumPageloadEventsAdaptiveGroups GraphQL dataset, AND is injected into the page as the beacon.
CF_WEB_ANALYTICS_SITE_TAG=

# Zone ID — brettfisher.dev "Overview" page, right sidebar "API" section.
# Only needed for zone traffic analytics (not RUM). Optional under the Web Analytics plan.
CLOUDFLARE_ZONE_ID=

# Days of traffic to summarize on the dashboard (default 7).
# CF_ANALYTICS_DAYS=7
